[10.939186, "o", ";5;251m: \u001b(B\u001b[m\u001b[38;5;139mu64\u001b(B\u001b[m\u001b[38;5;251m,\u001b[39m\u001b[K\u001b[38;5;251m\r\n}\u001b[39m\u001b[K\r\n\u001b[K\u001b[38;5;139m\r\nimpl\u001b(B\u001b[m\u001b[38;5;251m<V: Clone> Cache<V> {\u001b[39m\u001b[K\u001b[38;5;251m\r\n    \u001b(B\u001b[m\u001b[38;5;243m/// Create a new cache with the given TTL in seconds.\u001b[39m\u001b[K\u001b[38;5;251m\r\n    \u001b(B\u001b[m\u001b[38;5;139mpub\u001b(B\u001b[m\u001b[38;5;251m \u001b(B\u001b[m\u001b[38;5;139mfn\u001b(B\u001b[m\u001b[38;5;251m \u001b(B\u001b[m\u001b[38;5;109mnew\u001b(B\u001b[m\u001b[38;5;251m(\u001b(B\u001b[m\u001b[38;5;131mttl_secs\u001b(B\u001b[m\u001b[38;5;251m: \u001b(B\u001b[m\u001b[38;5;139mu64\u001b(B\u001b[m\u001b[38;5;251m) -> \u001b(B\u001b[m\u001b[38;5;139mSelf\u001b(B\u001b[m\u001b[38;5;251m {\u001b[39m\u001b[K\u001b[38;5;251m\r\n        \u001b(B\u001b[m\u001b[38;5;139mSelf\u001b(B\u001b[m\u001b[38;5;251m {\u001b[39m\u001b[K\u001b[38;5;251m\r\n            entries: HashMap::new(),\u001b[39m\u001b[K\u001b[38;5;251m\r\n            ttl: Duration::from_secs(ttl_secs),\u001b[39m\u001b[K\u001b[38;5;251m\r\n            hits: \u001b(B\u001b[m\u001b[38;5;173m0\u001b(B\u001b[m\u001b[38;5;251m,\u001b[39m\u001b[K\u001b[38;5;251m\r\n            misses: \u001b(B\u001b[m\u001b[38;5;173m0\u001b(B\u001b[m\u001b[38;5;251m,\u001b[39m\u001b[K\u001b[38;5;251m\r\n        }\u001b[39m\u001b[K\u001b[38;5;251m\r\n    }\u001b[39m\u001b[K\r\n\u001b[K\u001b[7m\r\n/tmp/pgr_demo.rs\u001b(B\u001b[m\u001b[K\u001b[37m\u001b[48;5;236m\r\n  /fn  (se                                        1:pgr-cli*    "]
